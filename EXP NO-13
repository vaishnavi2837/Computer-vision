import cv2
import numpy as np

# Read the image
image = cv2.imread("C:/Users/venka/OneDrive/Documents/opencv/sample.png")

if image is None:
    print("Error: Image not found!")
else:
    rows, cols, ch = image.shape

    # Select 3 points from original image
    pts1 = np.float32([[50, 50],
                       [200, 50],
                       [50, 200]])

    # Select corresponding 3 points in transformed image
    pts2 = np.float32([[10, 100],
                       [200, 50],
                       [100, 250]])

    # Create Affine Transformation Matrix
    matrix = cv2.getAffineTransform(pts1, pts2)

    # Apply Affine Transformation
    transformed = cv2.warpAffine(image, matrix, (cols, rows))

    # Display images
    cv2.imshow("Original Image", image)
    cv2.imshow("Affine Transformed Image", transformed)

    cv2.waitKey(0)
    cv2.destroyAllWindows()
